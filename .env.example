# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── LLM (required) ───────────────────────────────────────
# Any OpenAI-compatible endpoint (OpenAI, DeepSeek, gateway proxies, etc.).
LLM_API_KEY=sk-replace-me
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
# Tested models: deepseek-chat, deepseek-v4-pro (thinking mode handled
# transparently by the gateway layer — see docs/抽象边界原则.md).

# ── Database (required) ──────────────────────────────────
# Local install — make sure the DB exists and schema is loaded
# (see README "Setup" section).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recon_agent

# ── Optional ─────────────────────────────────────────────
# Remote Camoufox over WebSocket. Without these, the agent boots a local
# Camoufox process with per-domain persistent profile (recommended).
# Setting either of these forfeits per-domain profile persistence.
# BROWSER_WS_URL=ws://your-camoufox-host:1234/ws
# BROWSER_CDP_URL=http://your-chromium-host:9222

# Verification subagent (DONE gatekeeper). Defaults to true. Set to false
# to disable mid-mission gating (mark_done returns DONE immediately).
# VERIFICATION_SUBAGENT_ENABLED=true

# Custom artifacts root. Defaults to ./artifacts/
# ARTIFACTS_DIR=./artifacts
